# Copia para .env na raiz: Copy-Item .env.example .env
# Docker Compose: opcional (required: false); sem .env a API usa só as variáveis do compose.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5283
API_TITLE=Invoice Generator API

# Angular local (npm start). Com Docker: imagem do frontend usa ANGULAR_API_URL=/api (nginx → api:8080).
ANGULAR_API_URL=http://localhost:5283
ANGULAR_APP_TITLE=Invoice Generator
